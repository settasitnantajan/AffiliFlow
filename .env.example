# Supabase (server-only — ไม่หลุดไป browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Groq API (Llama 3.3 70B) — https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# Pexels (stock video fallback) — https://www.pexels.com/api
PEXELS_API_KEY=your-pexels-api-key

# Login password
AUTH_PASSWORD=your-password

# Optional
# SERPER_API_KEY=your-serper-key         # Google image search
# PIPELINE_SECRET=your-secret            # API security header
